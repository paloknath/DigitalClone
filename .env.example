# Pipeline selection: "google_s2s" or "deepgram_voice_agent"
PIPELINE_MODE=google_s2s

TEAMS_MEETING_URL=
BOT_NAME=AI Assistant
# Persona: set PERSONA_FILE to a .txt file path, or SYSTEM_INSTRUCTION inline.
# Leave both empty to use the default generic persona.
# PERSONA_FILE=persona.txt
SYSTEM_INSTRUCTION=
WS_PORT=8765

# ── Google S2S pipeline ─────────────────────────────────────
GOOGLE_API_KEY=
GEMINI_MODEL=models/gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_VOICE=Puck

# ── Deepgram Voice Agent pipeline ───────────────────────────
DEEPGRAM_API_KEY=
# STT: Deepgram Flux (end-of-turn detection <300ms)
DEEPGRAM_LISTEN_MODEL=flux-general-en
# LLM: OpenAI via Deepgram (bundled access)
DEEPGRAM_THINK_MODEL=gpt-4o-mini
# TTS: Cartesia via Deepgram (bundled access)
DEEPGRAM_SPEAK_MODEL=sonic-2
# Cartesia voice ID — browse voices at https://play.cartesia.ai/
CARTESIA_VOICE_ID=

# ── Meeting Memory (ChromaDB + Summary) ──────────────────────
# CHROMADB_PATH=./data/chromadb
GEMINI_SUMMARY_MODEL=gemini-2.5-flash-lite

# ── Vision Observer ───────────────────────────────────────────
VISION_ENABLED=false
VISION_INTERVAL=10
GEMINI_VISION_MODEL=gemini-2.5-flash-lite
